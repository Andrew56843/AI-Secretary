generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(cuid())
  phone                 String               @unique
  fullName              String?
  password              String
  rubleBalance          Int                  @default(0)
  minuteBalanceSeconds  Int                  @default(300)
  totalPurchasedSeconds Int                  @default(0)
  numberPurchasedAt     DateTime?
  numberRentExpiresAt   DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  profiles              AssistantProfile[]
  outboundContacts      OutboundContact[]
  billingTransactions   BillingTransaction[]
  googleAccount         GoogleAccount?
  telegramAccount       TelegramAccount?
  transcriptDeliveries  TranscriptDelivery[]
  phoneContactNames     PhoneContactName[]
}

model ReservedPhoneNumber {
  id        String             @id @default(cuid())
  number    String             @unique
  assigned  Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  profiles  AssistantProfile[]
}

model AssistantProfile {
  id               String              @id @default(cuid())
  userId           String
  mode             CallDirection
  title            String              @default("My AI Secretary")
  businessName     String?
  prompt           String
  greetingText     String
  forwardingPhone  String
  forwardingEnabled Boolean            @default(true)
  forwardingOnComplete Boolean         @default(true)
  forwardingOnStalemate Boolean        @default(true)
  realtimeModel   String              @default("gpt-realtime-2")
  voice           String              @default("alloy")
  maxDialogSeconds Int                 @default(120)
  status           ProfileStatus       @default(ACTIVE)
  reservedNumberId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservedNumber   ReservedPhoneNumber? @relation(fields: [reservedNumberId], references: [id])
  callLogs         CallLog[]

  @@unique([userId, mode])
  @@index([userId])
  @@index([reservedNumberId])
}

model CallLog {
  id               String           @id @default(cuid())
  assistantProfileId String
  direction        CallDirection
  customerPhone    String
  status           CallStatus
  durationSeconds  Int              @default(0)
  transcript       String?
  summary          String?
  recordingUrl     String?
  createdAt        DateTime         @default(now())

  assistantProfile AssistantProfile @relation(fields: [assistantProfileId], references: [id], onDelete: Cascade)
  transcriptDeliveries TranscriptDelivery[]

  @@index([assistantProfileId, createdAt])
  @@index([direction, createdAt])
}

model OutboundContact {
  id        String                @id @default(cuid())
  userId    String
  phone     String
  status    OutboundContactStatus @default(PENDING)
  queuedForCall Boolean             @default(false)
  attempts  Int                   @default(0)
  nextAttemptAt DateTime?
  lastCallLogId String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([userId, status])
}

model BillingTransaction {
  id            String                 @id @default(cuid())
  userId        String
  type          BillingTransactionType
  amountSeconds Int
  amountRub     Int?
  note          String?
  createdAt     DateTime               @default(now())

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GoogleAccount {
  id          String            @id @default(cuid())
  userId      String            @unique
  status      IntegrationStatus @default(DISCONNECTED)
  googleEmail String?
  calendarId  String?
  connectedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TelegramAccount {
  id          String            @id @default(cuid())
  userId      String            @unique
  status      IntegrationStatus @default(DISCONNECTED)
  botUsername String            @default("AISecretaryDemoBot")
  linkToken   String            @unique
  chatId      String?
  username    String?
  connectedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TranscriptDelivery {
  id             String                   @id @default(cuid())
  userId         String
  callLogId      String
  channel        TranscriptChannel
  status         TranscriptDeliveryStatus @default(PENDING)
  target         String?
  payloadPreview String?
  createdAt      DateTime                 @default(now())

  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  callLog        CallLog                  @relation(fields: [callLogId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([callLogId])
}

model PhoneContactName {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([userId])
}

enum ProfileStatus {
  ACTIVE
  PAUSED
}

enum CallStatus {
  SUCCESS
  ESCALATED
  MISSED
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum OutboundContactStatus {
  PENDING
  CALLED
  FAILED
}

enum BillingTransactionType {
  FREE_GRANT
  TOP_UP
  NUMBER_PURCHASE
  CALL_CHARGE
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
}

enum TranscriptChannel {
  TELEGRAM
}

enum TranscriptDeliveryStatus {
  PENDING
  SENT
  FAILED
}
